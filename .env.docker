APP_NAME=MockDasher
APP_ENV=production
APP_KEY=base64:hNqzY8hm/uMs98CgLfypOqiZtEMc+TGVJTkjViKL3Rk=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error
SENTRY_LOG_LEVEL=error

SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=MockDasherDB
DB_USERNAME=mockdasher
DB_PASSWORD=MockDasher_DB_2024!
DB_ROOT_PASSWORD=MockDasher_Root_2024!

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PERSISTENT=false

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@mockdasher.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS (optional) ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyArMjFbEdWdMjmEIGAKGM657vyfCp5cMXo
GEMINI_MODEL=gemini-2.5-flash

# ─── IELTS Precontexts ────────────────────────────────────────────────────────
IELTS_SPEAKING_PART1_CONTEXT="IELTS Speaking Part 1: The examiner asks the candidate about themselves, their home, work, studies, and other familiar topics. Answers should be natural and conversational, typically 2–3 sentences per question. Time: approximately 4–5 minutes."
IELTS_SPEAKING_PART2_CONTEXT="IELTS Speaking Part 2: The examiner gives the candidate a task card with a topic and bullet points. The candidate has 1 minute to prepare, then speaks for 1–2 minutes without interruption. The examiner may ask 1–2 follow-up questions."
IELTS_SPEAKING_PART3_CONTEXT="IELTS Speaking Part 3: The examiner and candidate discuss abstract topics linked to Part 2. Candidates should give extended, analytical answers with opinions, reasons, and examples. Time: approximately 4–5 minutes."
IELTS_WRITING_TASK1_CONTEXT="IELTS Academic Writing Task 1: The candidate should spend about 20 minutes on this task. They must summarise, describe or explain a graph, table, chart or diagram in their own words. They should select and report the main features and make comparisons where relevant. Minimum 150 words required."
IELTS_WRITING_TASK2_CONTEXT="IELTS Academic Writing Task 2: The candidate should spend about 40 minutes on this task. They must write an essay in response to a point of view, argument or problem. They should give reasons for their answer and include any relevant examples from their own knowledge or experience. Minimum 250 words required."

# ─── Port mapping (host side) ─────────────────────────────────────────────────
APP_PORT=8080
DB_PORT_EXPOSE=3307
